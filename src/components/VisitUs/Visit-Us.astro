</section>

<style>
  :root {
    --c-bg:      #0a0f1a;
    --c-surface: #111827;
    --c-card:    #141b2d;
    --c-border:  rgba(255,255,255,0.08);
    --c-accent:  #e8a020;
    --c-accent2: #f0c040;
    --c-text:    #f0f4ff;
    --c-muted:   #6b7280;
    --c-radius:  14px;
    --c-trans:   0.35s cubic-bezier(0.4,0,0.2,1);
  }

  /* ── SECTION ── */
  .contact-section {
    width: 100%;
    background: var(--c-bg);
    padding: 80px 5% 80px;
    position: relative;
    overflow: hidden;
  }

  /* patrón punteado de fondo */
  .contact-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  /* ── HEADER ── */
  .contact-header {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-bottom: 64px;
  }

  .header-pill {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #000;
    background: var(--c-accent);
    padding: 5px 16px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .contact-title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 900;
    color: var(--c-text);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 16px;
  }

  .title-brand {
    background: linear-gradient(120deg, var(--c-accent), var(--c-accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  .contact-subtitle {
    font-size: 1rem;
    color: var(--c-muted);
    margin: 0;
  }

  /* ── GRID ── */
  .contact-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 32px;
    max-width: 1200px;
    margin: 0 auto 48px;
    align-items: start;
  }

  /* ── INFO COLUMN ── */
  .info-column {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .info-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: var(--c-radius);
    padding: 18px 20px;
    text-decoration: none;
    transition: border-color var(--c-trans), transform var(--c-trans), box-shadow var(--c-trans);
    cursor: pointer;
  }

  .info-card:hover {
    border-color: var(--c-accent);
    transform: translateX(4px);
    box-shadow: -4px 0 0 var(--c-accent), 0 8px 24px rgba(0,0,0,0.3);
  }

  .info-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(232,160,32,0.12);
    border: 1px solid rgba(232,160,32,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-accent);
    flex-shrink: 0;
    transition: background var(--c-trans);
  }

  .info-card:hover .info-icon {
    background: var(--c-accent);
    color: #000;
  }

  .info-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .info-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-muted);
  }

  .info-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--c-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .info-sub {
    font-size: 12px;
    color: var(--c-muted);
  }

  .info-arrow {
    color: var(--c-muted);
    flex-shrink: 0;
    transition: color var(--c-trans), transform var(--c-trans);
  }

  .info-card:hover .info-arrow {
    color: var(--c-accent);
    transform: translateX(4px);
  }

  /* WhatsApp CTA */
  .whatsapp-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px;
    margin-top: 4px;
    background: #25d366;
    color: #fff;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.04em;
    border-radius: var(--c-radius);
    text-decoration: none;
    transition: background var(--c-trans), transform var(--c-trans);
  }

  .whatsapp-btn:hover {
    background: #1ebe57;
    transform: translateY(-2px);
  }

  /* ── MAPA ── */
  .map-column {
    position: relative;
  }

  .map-wrap {
    position: relative;
    border-radius: var(--c-radius);
    overflow: hidden;
    border: 1px solid var(--c-border);
    box-shadow: 0 24px 64px rgba(0,0,0,0.5);
  }

  .map-iframe {
    width: 100%;
    height: 520px;
    display: block;
    border: none;
    filter: grayscale(25%) contrast(1.05);
  }

  /* badge sobre el mapa */
  .map-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--c-text);
    backdrop-filter: blur(8px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  }

  /* ── FOOTNOTE ── */
  .contact-footnote {
    position: relative;
    z-index: 1;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-muted);
    margin: 0;
    padding-top: 16px;
    border-top: 1px solid var(--c-border);
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .map-iframe {
      height: 340px;
    }

    .map-column {
      order: -1;
    }
  }

  @media (max-width: 480px) {
    .contact-section { padding: 56px 4% 56px; }
    .contact-title { font-size: 2rem; }
    .info-value { font-size: 13px; }
  }
</style>